{
  "expo": {
    "name": "Zentory",
    "slug": "zentory",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zentory",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF",
      "dark": {
        "image": "./assets/images/splash-dark.png",
        "backgroundColor": "#16181D"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.zentory.app",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ch.zentory.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#236B56"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.NFC"
      ],
      "androidManifest": {}
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Zentory benötigt Kamerazugriff zum Scannen von Barcodes.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#236B56",
          "defaultChannel": "default",
          "androidMode": "default",
          "androidCollapsedTitle": "#{unread_notifications} neue Mitteilungen"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9b0d1f7e-01c6-45bd-87c5-164b4bb7216f"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "brainbytes"
  }
}
